          "query": "from(bucket: \"telegraf\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"prometheus_remote_write\")\n  |> filter(fn: (r) => r._field == \"container_last_seen\" and r.name != \"\")\n  |> group()\n  |> distinct(column: \"name\")\n  |> count()",
